<!-- Scroll to Top Button-->
<a class="scroll-to-top rounded" href="#page-top">
  <i class="fas fa-angle-up"></i>
</a>

<form action="" method="POST" hidden id="form__delete"></form>

<%- include('add_modal.ejs') %> <%- include('edit_modal.ejs') %>

<%-
include('../../partials/js.ejs') %>

<script>
  $("#dataTable").on("click", ".btn__edit", function () {
    const modalEdit = $("#modal__edit");
    modalEdit.find("form input[name=nameBank]").val($(this).data("namebank"));
    modalEdit
      .find("form input[name=nomorRekening]")
      .val($(this).data("nomorrekening"));
    modalEdit.find("form input[name=name]").val($(this).data("name"));
    modalEdit.find("form input[name=id]").val($(this).data("id"));
    modalEdit.modal("show");
  });

  $("#dataTable").on("click", ".btn__delete", function () {
    const id = $(this).data("id");
    const form = $("#form__delete");
    form.prop("action", `/admin/bank/${id}?_method=DELETE`);
    form.submit();
  });
</script>
