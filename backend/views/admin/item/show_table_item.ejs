<!-- DataTales Example -->
<div
  class="tab-pane fade show active"
  id="show-item"
  role="tabpanel"
  aria-labelledby="show-item-tab"
>
  <div class="card shadow mb-4 mt-2">
    <div class="card-body">
      <div class="table-responsive">
        <table
          class="table table-bordered"
          id="dataTable"
          width="100%"
          cellspacing="0"
        >
          <thead>
            <tr>
              <th>No.</th>
              <th>Title</th>
              <th>Price</th>
              <th>Country</th>
              <th>City</th>
              <th class="text-center">Action</th>
            </tr>
          </thead>
          <tbody>
            <% for( let i=0; i < item.length; i++ ) { %>
            <tr>
              <td><%= i + 1 %></td>
              <td><%= item[i].title %></td>
              <td><%= item[i].price %></td>
              <td><%= item[i].country %></td>
              <td><%= item[i].city %></td>
              <td class="text-center">
                <a
                  href="/admin/item/show-image/<%= item[i].id %>"
                  class="btn btn-sm btn-circle btn-info"
                >
                  <i class="fas fa-image"></i>
                </a>
                <a
                  href="/admin/item/<%= item[i].id %>"
                  class="btn btn-sm btn-circle btn-warning"
                  ><i class="fas fa-edit"></i
                ></a>
                <button
                  data-id="<%= item[i].id %>"
                  class="btn btn-sm btn-circle btn-danger btn__delete"
                >
                  <i class="fas fa-trash"></i>
                </button>
                <a
                  href="/admin/item/show-detail-item/<%= item[i].id %>"
                  class="btn btn-sm btn-circle btn-success"
                >
                  <i class="fas fa-plus"></i>
                </a>
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
