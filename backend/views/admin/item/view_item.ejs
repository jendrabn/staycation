<%- include('../../partials/header.ejs') %>

<!-- Page Wrapper -->
<div id="wrapper">
  <!-- Sidebar -->
  <%- include('../../partials/sidebar.ejs') %>
  <!-- End of Sidebar -->

  <!-- Content Wrapper -->
  <div id="content-wrapper" class="d-flex flex-column">
    <!-- Main Content -->
    <div id="content">
      <!-- Topbar -->
      <%- include('../../partials/navbar.ejs') %>
      <!-- End of Topbar -->

      <!-- Begin Page Content -->
      <div class="container-fluid">
        <%- include('../../partials/message.ejs') %>
        <!-- Page Heading -->
        <h1 class="h3 mb-4 text-gray-800">Item</h1>
        <!-- End Page Heading -->
        <% if (action=='view' ) { %>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
          <li class="nav-item" role="presentation">
            <a
              class="nav-link active"
              id="show-item-tab"
              data-toggle="tab"
              href="#show-item"
              role="tab"
              aria-controls="show-item"
              aria-selected="true"
              >Show Item</a
            >
          </li>
          <li class="nav-item" role="presentation">
            <a
              class="nav-link"
              id="add-item-tab"
              data-toggle="tab"
              href="#add-item"
              role="tab"
              aria-controls="add-item"
              aria-selected="false"
              >Add Item</a
            >
          </li>
        </ul>
        <div class="tab-content" id="myTabContent">
          <%- include('show_table_item.ejs') %> <%- include('add_item.ejs') %>
        </div>
        <% } else if(action=='show image' ){ %>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
          <li class="nav-item" role="presentation">
            <a
              class="nav-link active"
              id="show-image-item-tab"
              data-toggle="tab"
              href="#show-image-item"
              role="tab"
              aria-controls="show-image-item"
              aria-selected="true"
              >Show Image Item</a
            >
          </li>
        </ul>
        <div class="tab-content" id="myTabContent">
          <%- include('show_image_item.ejs') %>
        </div>
        <% } else if(action=='edit' ) { %>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
          <li class="nav-item" role="presentation">
            <a
              class="nav-link active"
              id="edit-item-tab"
              data-toggle="tab"
              href="#edit-item"
              role="tab"
              aria-controls="edit-item"
              aria-selected="true"
              >Show Edit Item</a
            >
          </li>
        </ul>
        <div class="tab-content" id="myTabContent">
          <%- include('edit_item.ejs') %>
        </div>
        <% } %>
      </div>
      <!-- /.container-fluid -->
    </div>
    <!-- End of Main Content -->

    <!-- Footer -->
    <%- include('../../partials/footer.ejs') %>
    <!-- End of Footer -->
  </div>
  <!-- End of Content Wrapper -->
</div>
<!-- End of Page Wrapper -->

<!-- Scroll to Top Button-->
<a class="scroll-to-top rounded" href="#page-top">
  <i class="fas fa-angle-up"></i>
</a>

<form action="" method="POST" hidden id="form__delete"></form>

<%- include('../../partials/js.ejs') %>

<script>
  $("#dataTable").on("click", ".btn__delete", function () {
    const id = $(this).data("id");
    const form = $("#form__delete");
    form.prop("action", `/admin/item/${id}?_method=DELETE`);
    form.submit();
  });
</script>
