<!-- DataTales Example -->
<div
  class="tab-pane fade show active"
  id="show-image-item"
  role="tabpanel"
  aria-labelledby="show-image-item-tab"
>
  <div class="row mt-2">
    <% for( let i=0; i < item.imageId.length; i++ ) { %>
    <div class="col-md-4 mb-4">
      <img
        src="https://admstaycation.herokuapp.com/<%=item.imageId[i].imageUrl  %>"
        class="img-thumbnail img-fluid"
      />
    </div>
    <% } %>
  </div>
  <a class="btn btn-warning" href="/admin/item">Back</a>
</div>
