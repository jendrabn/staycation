<div class="card shadow mb-4 mt-2">
  <div class="card">
    <div class="card-body">
      <div class="row">
        <div class="col-md-4">
          <img
            src="https://admstaycation.herokuapp.com/<%= booking.payments.proofPayment %>"
            class="w-100 d-block"
            alt="Bukti Pembayaran"
          />

          <% if (booking.payments.status === 'Process') { %>
          <div class="d-flex mt-2">
            <form
              action="/admin/booking/<%= booking.id %>/confirmation?_method=PUT"
              method="post"
            >
              <button type="submit" class="btn btn-success mr-2">
                <i class="fas fa-check"></i> Confirmation
              </button>
            </form>
            <form
              action="/admin/booking/<%= booking.id %>/reject?_method=PUT"
              method="post"
            >
              <button type="submit" class="btn btn-danger">
                <i class="fas fa-times"></i>
                Reject
              </button>
            </form>
          </div>
          <% } %>
        </div>
        <div class="col-md-8">
          <table class="table table-bordered" width="100%" cellspacing="0">
            <thead>
              <tr>
                <th>Name Member</th>
                <th>Total</th>
                <th>Bank From</th>
                <th>Title</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>
                  <%= `${booking.memberId.firstName}
                  ${booking.memberId.lastName}` %>
                </td>
                <td>$ <%= booking.total %></td>
                <td><%= booking.payments.bankFrom %></td>
                <td><%= booking.itemId.title %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
